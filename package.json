{
  "name": "obsidian-llm",
  "version": "0.9.2",
  "description": "Obsidian plugin for integrating with multiple LLM CLI tools",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "llm",
    "ai",
    "claude",
    "opencode",
    "codex",
    "gemini"
  ],
  "author": "Kai Detmers",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^20.19.39",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.12",
    "obsidian": "^1.12.3",
    "tslib": "^2.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@temroi/cai": "^1.5.0",
    "minisearch": "^7.2.0",
    "zod": "^4.3.6"
  }
}
