{
  "name": "obsidian-llm",
  "version": "0.5.8",
  "description": "Obsidian plugin for integrating with multiple LLM CLI tools",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test:e2e": "npm run build && wdio run ./wdio.conf.ts",
    "test:e2e:fast": "npm run build && wdio run ./wdio.conf.ts --spec test/specs/plugin.e2e.ts",
    "test:e2e:claude": "npm run build && wdio run ./wdio.conf.ts -- --mochaOpts.grep @claude",
    "test:e2e:gemini": "npm run build && wdio run ./wdio.conf.ts -- --mochaOpts.grep @gemini",
    "test:e2e:providers": "npm run build && wdio run ./wdio.conf.ts -- --mochaOpts.grep @provider",
    "test:e2e:files": "npm run build && wdio run ./wdio.conf.ts -- --mochaOpts.grep @files",
    "wdio": "wdio run ./wdio.conf.ts"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "llm",
    "ai",
    "claude",
    "opencode",
    "codex",
    "gemini"
  ],
  "author": "Kai Detmers",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.12",
    "expect-webdriverio": "^5.6.5",
    "obsidian": "^1.12.3",
    "tslib": "^2.4.0",
    "typescript": "^5.0.0",
    "wdio-obsidian-reporter": "^2.4.0",
    "wdio-obsidian-service": "^2.4.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@temroi/cai": "^1.5.0",
    "minisearch": "^7.2.0",
    "zod": "^4.3.6"
  }
}
